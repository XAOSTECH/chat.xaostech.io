---
import ChatIsland from '../components/ChatIsland.jsx';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>XAOS Chat</title>
    <link rel="icon" type="image/png" href="/api/data/assets/XAOSTECH_LOGO.png" />
    <link rel="shortcut icon" href="/api/data/assets/XAOSTECH_LOGO.png" />
    <style>
      /* Minimal CSS to match previous UI (kept concise) */
      :root{--primary-color:#f6821f}
      body{font-family: Cantarell, sans-serif; margin:0;padding:1rem}
    </style>
  </head>
  <body>
    <header>
      <h1>⚡ XAOS Chat</h1>
      <div class="model-info">Model: @cf/meta/llama-3.3-70b-instruct-fp8-fast</div>
    </header>

    <main>
      <ChatIsland client:load />
      <noscript>
        <style>.chat-noscript{max-width:600px;margin:2rem auto;padding:1.5rem;border:1px solid #444;border-radius:8px;background:#1a1a2e;color:#e0e0e0}</style>
        <div class="chat-noscript">
          <h2>Chat requires JavaScript</h2>
          <p>XAOS Chat uses a real-time streaming interface that needs JavaScript enabled.</p>
          <p>You can still interact with the AI via the <a href="https://api.xaostech.io" style="color:var(--primary-color)">API</a> directly, or enable JavaScript to use this interface.</p>
        </div>
      </noscript>
    </main>

    <script>
      import '../../shared/scripts/bubble.js';
    </script>
  </body>
</html>